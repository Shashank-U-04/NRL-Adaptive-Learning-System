# ── NRL Adaptive Learning Platform — Frontend Environment ─────────────
# Copy to `frontend/.env.local` and fill in real values. NEVER commit
# the resulting `.env.local`. The anon key is intended to be public, but
# the URL + anon key pair identifies a specific Supabase project — keep
# the file out of git anyway.

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY

# Backend API — local dev default. In production, set this to the
# deployed backend origin (e.g. https://nrl-adaptive-api.fly.dev).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
