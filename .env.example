# ── NRL Adaptive Learning Platform — Environment Variables ─────────────
# Copy to .env and fill in real values.

# ── App ────────────────────────────────────────────────────────────────
APP_NAME=NRL Adaptive Learning System
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Database (PostgreSQL — Neon recommended) ───────────────────────────
# Get connection string from Neon dashboard → Connection Details
DATABASE_URL=postgresql+asyncpg://user:password@host/db

# ── Supabase Auth (REQUIRED) ───────────────────────────────────────────
# Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# ── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Adaptive RL Engine ─────────────────────────────────────────────────
RL_EXPLORATION_RATE=0.05

# ── Session ────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=3600
