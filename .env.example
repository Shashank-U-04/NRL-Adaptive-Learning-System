# ── NRL Adaptive Learning Platform — Environment Variables ─────────────
# Copy this file to .env and fill in real values

# App
APP_NAME=NRL Adaptive Learning System
DEBUG=true

# JWT Auth — CHANGE IN PRODUCTION!
SECRET_KEY=nrl-dev-secret-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL — use postgresql+asyncpg:// for async SQLAlchemy
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nrl_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your_openrouter_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-chat

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# RL Engine
RL_EXPLORATION_RATE=0.05
