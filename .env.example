# ── NRL 2.0 Environment Variables ─────────────────────────
# Copy this file to .env and edit as needed

# App
APP_NAME=NRL 2.0
DEBUG=true

# JWT Auth (CHANGE IN PRODUCTION!)
SECRET_KEY=nrl-dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RL Engine
RL_EXPLORATION_RATE=0.05
