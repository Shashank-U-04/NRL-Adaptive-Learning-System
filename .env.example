# ── NRL Adaptive Learning Platform — Environment Variables ─────────────
# Copy this file to .env and fill in real values. Defaults work for local dev.

# ── App ────────────────────────────────────────────────────
APP_NAME=NRL Adaptive Learning System
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# ── JWT Auth — CHANGE IN PRODUCTION! ───────────────────────
SECRET_KEY=nrl-dev-secret-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────
# Production / Neon (recommended): postgres connection string
DATABASE_URL=postgresql+asyncpg://user:password@host/db
# Local dev fallback:
# DATABASE_URL=sqlite+aiosqlite:///./nrl.db

# ── Redis (OPTIONAL — leave empty to use built-in in-memory) ─
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# ── AI Provider ────────────────────────────────────────────
# Options: ollama (free, local) | openai | none
AI_PROVIDER=ollama

# Ollama (free, local LLM)
# Run separately:  ollama serve   (then `ollama pull mistral`)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_SECONDS=120

# OpenAI / OpenRouter (optional paid fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Set OPENAI_BASE_URL to use OpenRouter or another OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Together.ai (optional free-tier API)
TOGETHER_API_KEY=
TOGETHER_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# Monthly budget alert threshold (USD)
AI_MONTHLY_BUDGET_USD=10.0

# Days to keep cached AI modules before regenerating (0 = never expire)
CACHE_EXPIRY_DAYS=0

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── RL Engine ──────────────────────────────────────────────
RL_EXPLORATION_RATE=0.05

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute

# ── Observability ──────────────────────────────────────────
METRICS_ENABLED=true
